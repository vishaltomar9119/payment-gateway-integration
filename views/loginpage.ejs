<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Login</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      background: #f2f2f2;
      height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .login-box {
      background: #fff;
      padding: 30px;
      width: 350px;
      border-radius: 8px;
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
      text-align: center;
    }

    .login-box h2 {
      margin-bottom: 20px;
    }

    .google-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      background: #fff;
      border: 1px solid #ccc;
      padding: 10px;
      width: 100%;
      border-radius: 5px;
      cursor: pointer;
      font-size: 14px;
    }

    .google-btn:hover {
      background: #f7f7f7;
    }

    .google-btn img {
      width: 18px;
      height: 18px;
    }

    .divider {
      margin: 20px 0;
      color: #888;
      font-size: 14px;
    }
  </style>
</head>
<body>

  <div class="login-box">
    <h2>Sign In</h2>

    <!-- Google Login -->
    <a href="/auth/google" style="text-decoration: none;">
      <div class="google-btn">
        <img src="https://developers.google.com/identity/images/g-logo.png" alt="Google logo">
        <span>Continue with Google</span>
      </div>
    </a>

    <div class="divider">— OR —</div>

    <!-- Optional: Normal Login (if you add later) -->
    <p style="font-size: 13px; color: #666;">
      Login using your Google account
    </p>
  </div>

</body>
</html>
